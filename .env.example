# Supabase — copie este arquivo para `.env` e preencha com os dados do seu projeto.
# (Settings → API no painel do Supabase). Apenas variáveis com prefixo VITE_ ficam
# acessíveis no front-end via import.meta.env.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key
