# Supabase — copie este arquivo para `.env.local` e preencha com os dados do seu projeto.
# (Settings → API no painel do Supabase).
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Opcional, mas recomendado para performance: a service_role key (Settings → API →
# "service_role", em "Project API keys"). Habilita o cache de leitura server-side —
# sem ela, o app funciona igual, só sem esse ganho. NUNCA prefixar com NEXT_PUBLIC_
# (é uma chave secreta, só server-side, ignora RLS).
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
